<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss} %level]: %msg%n"/>

            <!-- 🔥 FILTER HEIGHTMAP WARNING -->
            <RegexFilter regex=".*heightmap.*" onMatch="DENY" onMismatch="NEUTRAL"/>
        </Console>
    </Appenders>

    <Loggers>

        <!-- Chunk system -->
        <Logger name="net.minecraft.world.level.chunk" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Logger name="net.minecraft.server.level.ChunkMap" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>

    </Loggers>

</Configuration>